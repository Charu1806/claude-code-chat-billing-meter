# Copy this file to .env and fill in your key
# cp .env.example .env

# ── Anthropic ────────────────────────────────────────────────────────────────
# Required for Tab 1 (Code Writer) and Tab 2 (Chatbot).
# Tabs 3, 4, 5 (cost calculators) work without this.
# Get your key → https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ── Which model to use in Tab 1 (Code Writer) ────────────────────────────────
# Default: claude-sonnet-4-6  (best speed/cost balance)
# Options:
#   claude-opus-4-8       → most capable, most expensive ($5/$25 per 1M)
#   claude-sonnet-4-6     → balanced, default ($3/$15 per 1M)
#   claude-haiku-4-5      → fastest, cheapest ($1/$5 per 1M)
CODE_WRITER_MODEL=claude-sonnet-4-6

# ── Default model pre-selected in Tab 2 (Chatbot) ────────────────────────────
# User can still change it from the sidebar dropdown.
# Same options as CODE_WRITER_MODEL above.
CHAT_DEFAULT_MODEL=claude-sonnet-4-6
