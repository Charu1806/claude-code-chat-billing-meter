# Copy this file to .env and fill in your keys
# cp .env.example .env

# ── Anthropic ─────────────────────────────────────────────────────────────────
# Required for: Claude Opus 4.8, Claude Sonnet 4.6, Claude Haiku 4.5
# Get key → https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ── Google ────────────────────────────────────────────────────────────────────
# Required for: Gemini 2.5 Flash, Gemini 2.5 Pro
# Get key → https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=AIza...

# ── Groq ──────────────────────────────────────────────────────────────────────
# Required for: Mistral Saba, Llama 3.3 70B, Llama 3.1 8B  (all via Groq)
# Get key → https://console.groq.com/keys
GROQ_API_KEY=gsk_...

# ── Default active model (shown pre-selected in the sidebar) ──────────────────
# Options (must match a key in LIVE_MODELS in app.py):
#   claude-opus-4-8       Anthropic — most capable
#   claude-sonnet-4-6     Anthropic — balanced (default)
#   claude-haiku-4-5      Anthropic — fastest / cheapest
#   gemini-2.5-flash      Google
#   gemini-2.5-pro        Google
#   mistral-saba          Groq / Mistral
#   llama-3.3-70b         Groq / Meta
#   llama-3.1-8b          Groq / Meta
CODE_WRITER_MODEL=claude-sonnet-4-6
